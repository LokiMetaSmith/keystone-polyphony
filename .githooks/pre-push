#!/usr/bin/env bash
set -euo pipefail

# Keystone Polyphony - Pre-push Hook
#
# This hook runs before 'git push'. It prevents direct pushes to 'main'
# and ensures all tests pass.

# 0. Local Override
# Source personal local hooks if they exist
LOCAL_HOOK=".git/hooks/pre-push.local"
if [ -x "$LOCAL_HOOK" ]; then
  echo "pre-push: Running local override hook..."
  if ! "$LOCAL_HOOK"; then
    echo "[ERROR] pre-push: Local hook failed. Push aborted."
    exit 1
  fi
fi


# 1. Branch Protection
# The hook receives information about what is being pushed on stdin:
# <local ref> <local sha1> <remote ref> <remote sha1>
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "${ALLOW_MAIN_PUSH:-0}" != "1" ]; then
    echo "[ERROR] Pushing directly to 'main' is discouraged. Please use a feature branch."
    echo "        To override, set ALLOW_MAIN_PUSH=1"
    exit 1
  fi
done

# 2. Run Tests
# Execute the centralized test script.
echo "pre-push: Running repository health checks..."
if ! ./scripts/run-tests.sh; then
  echo "[ERROR] pre-push: Health checks failed. Push aborted."
  exit 1
fi

echo "pre-push: All checks passed. Proceeding with push."
exit 0
