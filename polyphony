#!/usr/bin/env bash
# polyphony - The Native Swarm CLI Wrapper for Keystone Polyphony

set -e

# Detect python executable (avoiding Windows Store stubs)
if command -v python3 &>/dev/null && python3 -c "import sys" 2>/dev/null; then
    PYTHON_EXEC="python3"
elif command -v python &>/dev/null && python -c "import sys" 2>/dev/null; then
    PYTHON_EXEC="python"
else
    echo "❌ ERROR: Python is not installed or not working correctly."
    exit 1
fi

# Ensure we have SWARM_KEY
if [ -z "$SWARM_KEY" ]; then
    if [ -f .env ]; then
        # Load from .env if it exists
        export $(grep -v '^#' .env | xargs)
    fi
fi

if [ -z "$SWARM_KEY" ]; then
    echo "❌ ERROR: SWARM_KEY is not set. Please export it or define it in .env"
    exit 1
fi

usage() {
    echo "Usage: polyphony <command> [args...] (or 'kp <command>')"
    echo ""
    echo "Core Commands:"
    echo "  start|join       Start the Liminal Bridge (Seed Mode)"
    echo "  worker|daemon    Start the Liminal Bridge (Daemon/Worker Mode)"
    echo "  dashboard [port] Start the bridge with the web dashboard (default: 8000)"
    echo "  setup            Provision the environment and join the swarm"
    echo ""
    echo "Coordination Commands:"
    echo "  status [msg]     Show swarm state, or update your node status if msg is provided"
    echo "  idle             Quickly set your node status to 'idle'"
    echo "  share <thought>  Broadcast a thought to the swarm"
    echo "  ping <id> <msg>  Directly notify another agent"
    echo "  task <action>    Manage tasks: list, add, claim, complete"
    echo "  broadcast <cmd>  Broadcast a command to the swarm"
    echo "  chat <topic> <msg> Post a message to an ensemble chat topic"
    echo "  topics           List all active chat topics"
    echo ""
    echo "Project Commands:"
    echo "  dispatch <file>  Dispatch a work order to multiple agents"
    echo "  issue <action>   Refine or deduplicate issues (refine|dedup)"
    echo "  keys             Exchange SSH keys with the swarm"
    echo "  lint             Run the project linters"
    echo "  test             Run the project tests"
    echo "  hooks            Install the local git hooks"
    echo "  help             Display this help message"
    echo ""
}

case "$1" in
    join|start)
        echo ">>> Joining the Polyphony Swarm (Seed Mode)..."
        exec $PYTHON_EXEC src/liminal_bridge/server.py --mode seed "${@:2}"
        ;;
    daemon|worker)
        echo ">>> Starting Polyphony Daemon (Worker Mode)..."
        exec $PYTHON_EXEC src/liminal_bridge/server.py --mode daemon "${@:2}"
        ;;
    dashboard)
        PORT="${2:-8000}"
        echo ">>> Starting Swarm Dashboard on port $PORT..."
        exec $PYTHON_EXEC src/liminal_bridge/server.py --mode seed --dashboard-port "$PORT" "${@:3}"
        ;;
    setup)
        ./scripts/setup-ensemble.sh
        ;;
    status)
        if [ -n "$2" ]; then
            $PYTHON_EXEC scripts/status.py "$2"
        else
            $PYTHON_EXEC scripts/swarm_status.py
        fi
        ;;
    list|tasks)
        $PYTHON_EXEC scripts/swarm_status.py
        ;;
    idle)
        $PYTHON_EXEC scripts/status.py "idle"
        ;;
    share)
        if [ -z "$2" ]; then
            echo "Usage: polyphony share 'Your thought here'"
            exit 1
        fi
        $PYTHON_EXEC scripts/share.py "${@:2}"
        ;;
    ping)
        if [ -z "$2" ] || [ -z "$3" ]; then
            echo "Usage: polyphony ping <node_id> 'Your message here'"
            exit 1
        fi
        $PYTHON_EXEC scripts/ping.py "$2" "${@:3}"
        ;;
    task)
        shift
        $PYTHON_EXEC scripts/task.py "$@"
        ;;
    broadcast)
        shift
        $PYTHON_EXEC scripts/broadcast.py "$@"
        ;;
    chat)
        shift
        $PYTHON_EXEC scripts/chat.py "$@"
        ;;
    topics)
        $PYTHON_EXEC scripts/list_topics.py
        ;;
    dispatch)
        shift
        ./scripts/dispatch-work-order.sh "$@"
        ;;
    issue)
        shift
        case "$1" in
            refine)
                $PYTHON_EXEC scripts/refine_issue.py "$2"
                ;;
            dedup)
                $PYTHON_EXEC scripts/deduplicate.py
                ;;
            *)
                echo "Usage: polyphony issue <refine|dedup>"
                exit 1
                ;;
        esac
        ;;
    keys)
        echo ">>> Exchanging SSH keys with the Polyphony Swarm..."
        $PYTHON_EXEC scripts/exchange_ssh_keys.py "${@:2}"
        ;;
    lint)
        ./scripts/lint.sh
        ;;
    test)
        ./scripts/run-tests.sh
        ;;
    hooks)
        ./scripts/install-hooks.sh
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo "❌ Unknown command: $1"
        usage
        exit 1
        ;;
esac
