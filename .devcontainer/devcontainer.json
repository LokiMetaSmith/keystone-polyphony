{
  "name": "Keystone Polyphony",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "remoteUser": "phoenix",
  "postCreateCommand": "HEADLESS=1 SKIP_SSH_EXCHANGE=1 bash scripts/setup-ensemble.sh",
  "postStartCommand": "nohup ./polyphony worker > server.log 2>&1 &"
}